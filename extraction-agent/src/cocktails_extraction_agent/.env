# ==========================================================================|
# This is a template .env file. For local development purposes,             |  
# copy this file to .env.loc and fill in the values.                        |  
# The app_settings.json file is configured to read from environment         |
# variables and uses the currently configured ENV variable to               |
# determine which .env file to load.  For local development this ENV        |
# var is set to 'loc' in the launch.json and makefile.                      |
# --------------------------------------------------------------------------|
# (ex: .env.loc)                                                            |
# ==========================================================================|
# open telemetry / tracing settings                                         |
# --------------------------------------------------------------------------|
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
OTEL_SERVICE_NAMESPACE=
OTEL_OTLP_AUTH_HEADER=
OTEL_ENABLE_CONSOLE_LOGGING=
OTEL_ENABLE_TRACING=
OTEL_ENABLE_LOGGING=
# --------------------------------------------------------------------------|
# kafka settings                                                            |
# --------------------------------------------------------------------------|
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_CONSUMER_GROUP=
# --------------------------------------------------------------------------|
# extraction agent settings                                                 |
# --------------------------------------------------------------------------|
EXTRACTION_AGENT_ENABLED=
EXTRACTION_AGENT_KAFKA_TOPIC_NAME=
EXTRACTION_AGENT_KAFKA_NUM_CONSUMERS=
EXTRACTION_AGENT_KAFKA_RESULTS_TOPIC_NAME=
EXTRACTION_AGENT_KAFKA_MAX_POLL_INTERVAL_MS=
EXTRACTION_AGENT_KAFKA_AUTO_OFFSET_RESET=
EXTRACTION_AGENT_LLM_MODEL=
EXTRACTION_AGENT_LLM_MODEL_TEMPERATURE=
EXTRACTION_AGENT_LLM_MODEL_DISABLE_STREAMING=
EXTRACTION_AGENT_LLM_MODEL_NUM_PREDICT=
EXTRACTION_AGENT_LLM_MODEL_LOG_VERBOSE=
EXTRACTION_AGENT_LLM_GRAPH_TIMEOUT_SECONDS=
EXTRACTION_AGENT_LLM_MODEL_REASONING=
EXTRACTION_AGENT_LLM_MCP_URL=
EXTRACTION_AGENT_LLM_MCP_TRANSPORT=
EXTRACTION_AGENT_LLM_MCP_XKEY=
EXTRACTION_AGENT_USE_LLM=
# --------------------------------------------------------------------------|
# llm and langfuse settings                                                 |    
# LLM_HOST=http://localhost:11434                                           |
# --------------------------------------------------------------------------|
LLM_HOST=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=